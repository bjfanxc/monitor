<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MonitorAppAlertChannelMapper">

    <delete id="deleteByAppId" parameterType="Long">
        delete from monitor_app_alert_channel where app_id = #{appId}
    </delete>

    <delete id="deleteByAppIds">
        delete from monitor_app_alert_channel
        where app_id in
        <foreach collection="appIds" item="appId" open="(" separator="," close=")">
            #{appId}
        </foreach>
    </delete>

    <insert id="batchInsert">
        insert into monitor_app_alert_channel(app_id, channel_id, create_by, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.appId}, #{item.channelId}, #{item.createBy}, sysdate())
        </foreach>
    </insert>

</mapper>
