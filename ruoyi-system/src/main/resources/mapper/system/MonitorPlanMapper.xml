<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.MonitorPlanMapper">

    <resultMap id="MonitorPlanResult" type="com.ruoyi.system.domain.MonitorPlan">
        <id property="id" column="id" />
        <result property="planCode" column="plan_code" />
        <result property="planName" column="plan_name" />
        <result property="maxAlertChannels" column="max_alert_channels" />
        <result property="maxApps" column="max_apps" />
        <result property="scanIntervalMinutes" column="scan_interval_minutes" />
        <result property="sortOrder" column="sort_order" />
        <result property="isDefault" column="is_default" />
        <result property="status" column="status" />
        <result property="remark" column="remark" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectMonitorPlanVo">
        select id, plan_code, plan_name, max_alert_channels, max_apps, scan_interval_minutes,
               sort_order, is_default, status, remark, create_by, create_time, update_by, update_time
        from monitor_plan
    </sql>

    <select id="selectMonitorPlanById" parameterType="Long" resultMap="MonitorPlanResult">
        <include refid="selectMonitorPlanVo" />
        where id = #{id}
    </select>

    <select id="selectMonitorPlanByCode" parameterType="String" resultMap="MonitorPlanResult">
        <include refid="selectMonitorPlanVo" />
        where plan_code = #{planCode}
        limit 1
    </select>

    <select id="selectDefaultMonitorPlan" resultMap="MonitorPlanResult">
        <include refid="selectMonitorPlanVo" />
        where status = '0'
          and is_default = 1
        order by sort_order asc, id asc
        limit 1
    </select>

    <select id="selectMonitorPlanList" parameterType="com.ruoyi.system.domain.MonitorPlan" resultMap="MonitorPlanResult">
        <include refid="selectMonitorPlanVo" />
        <where>
            <if test="planCode != null and planCode != ''">
                and plan_code like concat('%', #{planCode}, '%')
            </if>
            <if test="planName != null and planName != ''">
                and plan_name like concat('%', #{planName}, '%')
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        order by is_default desc, sort_order asc, id asc
    </select>

    <insert id="insertMonitorPlan" parameterType="com.ruoyi.system.domain.MonitorPlan" useGeneratedKeys="true" keyProperty="id">
        insert into monitor_plan(
            plan_code, plan_name, max_alert_channels, max_apps, scan_interval_minutes,
            sort_order, is_default, status, remark, create_by, create_time
        ) values (
            #{planCode}, #{planName}, #{maxAlertChannels}, #{maxApps}, #{scanIntervalMinutes},
            #{sortOrder}, #{isDefault}, #{status}, #{remark}, #{createBy}, sysdate()
        )
    </insert>

    <update id="updateMonitorPlan" parameterType="com.ruoyi.system.domain.MonitorPlan">
        update monitor_plan
        <set>
            <if test="planCode != null and planCode != ''">plan_code = #{planCode},</if>
            <if test="planName != null and planName != ''">plan_name = #{planName},</if>
            <if test="maxAlertChannels != null">max_alert_channels = #{maxAlertChannels},</if>
            <if test="maxApps != null">max_apps = #{maxApps},</if>
            <if test="scanIntervalMinutes != null">scan_interval_minutes = #{scanIntervalMinutes},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="clearDefaultPlan">
        update monitor_plan
        set is_default = 0,
            update_time = sysdate()
        where is_default = 1
        <if test="excludeId != null">
            and id != #{excludeId}
        </if>
    </update>

    <delete id="deleteMonitorPlanByIds">
        delete from monitor_plan
        where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
